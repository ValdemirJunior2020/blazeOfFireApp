// File: app/firestore.rules
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn() && request.auth.token.email == "marcelo@blazeoffire.com";
    }

    match /users/{userId} {
      allow read, write: if signedIn() && request.auth.uid == userId;
    }

    match /prayer_requests/{docId} {
      allow create: if signedIn();
      allow read, update, delete: if isAdmin();
    }

    match /announcements/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /daily_devotionals/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /testimonies/{docId} {
      allow read: if true;
      allow create: if signedIn();
      allow update, delete: if isAdmin();
    }

    match /church_content/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /ministries/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}