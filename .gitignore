# Node.js / npm / pnpm / yarn
node_modules/
npm-debug.log
yarn-debug.log
yarn-error.log
.pnpm-debug.log
.pnpm-store/
.yarn/*
!.yarn/patches/
!.yarn/plugins/
!.yarn/releases/
!.yarn/sdks/
!.yarn/versions/
.yarn/install-state.gz

# Build outputs & transpiled code
dist/
build/
out/
coverage/
*.tsbuildinfo

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
lerna-debug.log*

# Environment variables & secrets
.env
.env.local
.env.*.local
.env.development.local
.env.test.local
.env.production.local

# Editor & OS files
.DS_Store
Thumbs.db
*.swp
*~
.vscode/
.idea/
*.sublime-*
*.code-workspace

# Testing artifacts
.nyc_output/
playwright-report/
test-results/
cypress/videos/
cypress/screenshots/

# Dependency directories (alternative names)
jspm_packages/
bower_components/

# Optional eslint / prettier cache
.eslintcache
.prettiercache

# Local development overrides
*.local.*

# Optional: lockfiles you might want to keep or ignore
# (uncomment the one you DON'T want to commit)
# package-lock.json      ← keep if using npm
# yarn.lock              ← keep if using Yarn
# pnpm-lock.yaml         ← keep if using pnpm
# shrinkwrap.yaml

# Optional large / generated files
*.min.js
*.min.css
*.gz
*.tgz
*.zip

# Bun (if you use it)
.bun/
bun.lockb